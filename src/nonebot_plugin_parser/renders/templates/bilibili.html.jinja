<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bilibili Card</title>
    {% from "comments.jinja" import render_comments %}
    {% include "share.html" %}
    <style>
        /* 封面上的标签 */
        .tag {
            position: absolute;
            top: 20px;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            color: white;
            display: flex;
            align-items: center;
            gap: 6px;
            backdrop-filter: blur(8px);
            background-color: rgba(0, 0, 0, 0.6);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            z-index: 2;
        }

        .type-tag {
            left: 20px;
            border-left: 3px solid var(--primary-color);
        }

        .platform-tag {
            right: 20px;
            border-left: 3px solid var(--secondary-color);
        }

        /* 播放按钮装饰 */
        .play-btn-overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 64px;
            height: 64px;
            background: rgba(255, 255, 255, 0.85);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--primary-color);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

        /* 作者信息与二维码区域 */
        .author-qr-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px dashed #eee;
        }

        .author-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .author-avatar {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        .author-details h3 {
            font-size: 19px;
            margin-bottom: 6px;
            color: var(--dark-color);
            font-weight: 700;
        }

        .author-meta {
            color: var(--gray-color);
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .info-badge {
            background-color: #f1f8ff;
            padding: 2px 8px;
            border-radius: 6px;
            font-weight: 600;
            font-family: Consolas, Monaco, monospace;
            font-size: 12px;
        }

        .info-badge.uid {
            color: var(--secondary-color);
            background-color: #eaf4fc;
        }

        .info-badge.content-id {
            color: #e67e22;
            background-color: #fdf2e9;
        }

        .time-text {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .time-text::before {
            content: "\f017";
            font-family: "Font Awesome 6 Free";
            font-weight: 400;
        }

        .qrcode-placeholder {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 4px;
            color: #ddd;
        }

        .qrcode-icon {
            font-size: 32px;
            color: #eee;
        }

        /* 统计数据区域 */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 25px;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background-color: #f8f9fa;
            border-radius: 10px;
            border-left: 4px solid transparent;
        }

        .stat-item:nth-child(1) {
            border-left-color: #e74c3c;
        }

        .stat-item:nth-child(2) {
            border-left-color: #3498db;
        }

        .stat-item:nth-child(3) {
            border-left-color: #2ecc71;
        }

        .stat-item:nth-child(4) {
            border-left-color: #f39c12;
        }

        .stat-item:nth-child(5) {
            border-left-color: #9b59b6;
        }

        .stat-item:nth-child(6) {
            border-left-color: #1abc9c;
        }

        .stat-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            color: white;
            flex-shrink: 0;
        }

        .stat-icon.play {
            background-color: #e74c3c;
        }

        .stat-icon.like {
            background-color: #3498db;
        }

        .stat-icon.reply {
            background-color: #2ecc71;
        }

        .stat-icon.fav {
            background-color: #f39c12;
        }

        .stat-icon.share {
            background-color: #9b59b6;
        }

        .stat-icon.coin {
            background-color: #1abc9c;
        }

        .stat-content {
            display: flex;
            flex-direction: column;
        }

        .stat-value {
            font-size: 17px;
            font-weight: 700;
            color: var(--dark-color);
            line-height: 1.1;
        }

        .stat-label {
            font-size: 12px;
            color: var(--gray-color);
            margin-top: 2px;
        }

        .ai-summary {
            background-color: #f8faff;
            padding: 16px 20px;
            border-radius: 10px;
            border: 1px solid #e1e8ed;
            margin-bottom: 20px;
            position: relative;
        }

        .ai-summary h4 {
            color: var(--secondary-color);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
            font-weight: 700;
        }

        .ai-summary p {
            color: #505c6b;
            font-size: 14px;
            line-height: 1.6;
            text-align: justify;
        }
    </style>
</head>

<body>

    {# === 宏定义：渲染卡片 === #}
    {% macro render_card(result, is_repost=False) %}

    {# 变量定义 #}
    {% set extra = result.extra if result.extra else {} %}
    {% set platform = result.platform %}
    {% set content_id = extra.content_id %}
    {% set stats = result.stats%}
    {% set type_tag = extra.type_tag if extra.type_tag else "B站" %}
    {% set type_icon = extra.type_icon if extra.type_icon else "fa-brands fa-bilibili" %}
    {% set type = extra.type if extra.type else "video" %}

    <div class="card" {% if is_repost %}style="width: 100%; margin-bottom: 0;" {% endif %}>
        {% if not is_repost %}
        <div class="decorative-stripe"></div>
        {% endif %}

        {# --- 封面区域 --- #}
        {% set cover_url = result.cover_path %}

        {% if cover_url %}
        <div class="cover-section">
            <img src="{{ cover_url }}" class="cover-image" alt="Cover">
            <div class="cover-overlay"></div>

            {% if extra.type_tag %}
            <div class="tag type-tag">
                <i class="fa-solid {{ extra.type_icon }}"></i>
                <span>{{ extra.type_tag }}</span>
            </div>
            {% endif %}

            <div class="tag platform-tag">
                <img src="https://i0.hdslb.com/bfs/static/jinkela/long/images/favicon.ico"
                    style="width: 16px; height: 16px; margin-right: 6px;">
                <span>BILIBILI</span>
            </div>

            {% if type in ['video', 'live'] %}
            <div class="play-btn-overlay">
                <i class="fas fa-play" style="margin-left: 4px;"></i>
            </div>
            {% endif %}
        </div>
        {% endif %}

        <div class="content-section">
            {# --- 作者信息行 --- #}
            {% if result.author %}
            <div class="author-qr-row">
                <div class="author-info">
                    <img src="{{ result.author.avatar_path or '' }}" class="author-avatar">
                    <div class="author-details">
                        <h3>{{ result.author.name }}</h3>
                        <div class="author-meta">
                            {% if result.author.id %}
                            <span class="info-badge uid">UID: {{ result.author.id }}</span>
                            {% endif %}
                            {% if content_id %}
                            <span class="info-badge content-id">{{ content_id }}</span>
                            {% endif %}
                            {% if result.formatted_datetime %}
                            <span class="time-text">{{ result.formatted_datetime }}</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="qrcode-placeholder">
                    {% if result.qr_code_path %}
                    <img src="{{ result.qr_code_path }}" alt="QR Code"
                        style="width: 77px; height: 77px; border-radius: 8px;" />
                    {% else %}
                    <i class="fas fa-qrcode qrcode-icon"></i>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            {# --- 统计数据 --- #}
            {% if stats %}
            {% set stat_items = [] %}

            {# 按照顺序：播放 弹幕 硬币 点赞 收藏 评论 分享 #}
            {# 只添加有值的统计项，没有值时不显示整个div盒子 #}

            {# 播放量 #}
            {% if stats.view_count and stats.view_count != '-' %}
            {% set _ = stat_items.append({'key': 'play', 'value': stats.view_count, 'label': '播放', 'icon': 'fa-eye',
            'color':
            '#e74c3c'}) %}
            {% endif %}

            {# 弹幕数 #}
            {% if stats.extra.danmaku and stats.extra.danmaku != '-' %}
            {% set _ = stat_items.append({'key': 'danmaku', 'value': stats.extra.danmaku, 'label': '弹幕', 'icon':
            'fa-comment-dots', 'color': '#3498db'}) %}
            {% endif %}

            {# 硬币数 #}
            {% if stats.coin and stats.coin != '-' %}
            {% set _ = stat_items.append({'key': 'coin', 'value': stats.coin, 'label': '硬币', 'icon': 'fa-coins',
            'color': '#f39c12'}) %}
            {% endif %}

            {# 点赞数 #}
            {% if stats.like_count and stats.like_count != '-' %}
            {% set _ = stat_items.append({'key': 'like', 'value': stats.like_count, 'label': '点赞', 'icon':
            'fa-thumbs-up',
            'color': '#2ecc71'}) %}
            {% endif %}

            {# 收藏数 #}
            {% if stats.collect_count and stats.collect_count != '-' %}
            {% set _ = stat_items.append({'key': 'favorite', 'value': stats.collect_count, 'label': '收藏', 'icon':
            'fa-star',
            'color': '#9b59b6'}) %}
            {% endif %}

            {# 评论数 #}
            {% if stats.comment_count and stats.comment_count != '-' %}
            {% set _ = stat_items.append({'key': 'reply', 'value': stats.comment_count, 'label': '评论', 'icon':
            'fa-comment',
            'color': '#1abc9c'}) %}
            {% endif %}

            {# 分享数 #}
            {% if stats.share_count and stats.share_count != '-' %}
            {% set _ = stat_items.append({'key': 'share', 'value': stats.share_count, 'label': '分享', 'icon': 'fa-share',
            'color': '#34495e'}) %}
            {% endif %}

            {# 只在有统计项时显示整个统计容器 #}
            {% if stat_items %}
            <div class="stats-container">
                {% for item in stat_items %}
                <div class="stat-item" style="border-left-color: {{ item.color }};">
                    <div class="stat-icon" style="background-color: {{ item.color }};">
                        <i class="fas {{ item.icon }}"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value">{{ item.value }}</div>
                        <div class="stat-label">{{ item.label }}</div>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% endif %}
            {% endif %}

            {# --- 主要标题 --- #}
            {% if result.title %}
            <div class="content-title">{{ result.title }}</div>
            {% endif %}

            {# --- AI 总结 --- #}
            {% if extra.info %}
            <div class="ai-summary">
                <h4><i class="fas fa-robot"></i> AI 内容总结</h4>
                <p>{{ extra.info }}</p>
            </div>
            {% endif %}

            {# --- 正文描述 --- #}
            <div>{{ result.content | safe }}</div>

            {# --- 旧版 Repost (保留兼容性) --- #}
            {% if result.repost %}
            <div
                style="margin-top: 20px; border: 1px solid #eee; background-color: #fafbfc; border-radius: 8px; padding: 15px;">
                <div style="margin-bottom:10px; color:#666; font-size:14px; font-weight:600;">
                    <i class="fas fa-share" style="margin-right:5px;"></i> 转发内容
                </div>
                <div style="width: 100%; overflow: hidden;">
                    {{ render_card(result.repost, is_repost=True) }}
                </div>
            </div>
            {% endif %}
        </div>
        {# --- 评论区 --- #}
        {{ render_comments(result) }}
        {# --- 底部 --- #}
        {% if not is_repost %}
        <div class="footer-section">
            <div class="footer-brand">
                <i class="fas fa-layer-group"></i>
                <span>{{ bot_name }} Parser || Designed By LoCCai</span>
            </div>
            <div class="footer-info">
                <i class="fas fa-clock" style="margin-right: 4px;"></i>
                <span>Rendering at {{ rendering_time }}</span>
            </div>
        </div>
        {% endif %}
    </div>
    {% endmacro %}

    {{ render_card(result) }}

</body>

</html>